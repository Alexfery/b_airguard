PORT=3000
CORS_ORIGIN=http://localhost:4200

# JWT
JWT_SECRET=airguard-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Supabase — obține din https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# HiveMQ Cloud — obține din https://console.hivemq.cloud
MQTT_HOST=YOUR_CLUSTER_ID.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=airguard-device
MQTT_PASSWORD=YOUR_HIVEMQ_PASSWORD
MQTT_CLIENT_ID=airguard-backend
